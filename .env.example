# Ninja API base URL, for example: https://app.ninjarmm.com
NINJA_BASE_URL=

# Provide exactly one auth mode OR both if your tenant supports either
NINJA_BEARER_TOKEN=
NINJA_SESSION_KEY=

# OAuth2 Client Credentials (optional alternative to static bearer token)
# If used, set all three required values below.
NINJA_OAUTH_TOKEN_URL=
NINJA_OAUTH_CLIENT_ID=
NINJA_OAUTH_CLIENT_SECRET=

# Optional OAuth fields (provider-specific)
NINJA_OAUTH_SCOPE=
NINJA_OAUTH_AUDIENCE=

# Optional behavior tuning
NINJA_HTTP_TIMEOUT_MS=30000
NINJA_HTTP_RETRY_COUNT=2
NINJA_DEFAULT_PAGE_SIZE=100
NINJA_MAX_PAGE_SIZE=1000

# MCP server listening port
PORT=3000
